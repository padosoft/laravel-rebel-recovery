{
  "name": "padosoft/laravel-rebel-recovery",
  "description": "High-assurance account recovery for Laravel Rebel: single-use HMAC-hashed recovery (backup) codes, generated once at enrolment, with anti-ATO checks. Part of padosoft/laravel-rebel-*.",
  "license": "MIT",
  "keywords": [
    "laravel",
    "authentication",
    "security",
    "padosoft",
    "rebel"
  ],
  "homepage": "https://github.com/padosoft/laravel-rebel-recovery",
  "authors": [
    {
      "name": "Padosoft",
      "email": "support@padosoft.com",
      "homepage": "https://www.padosoft.com"
    }
  ],
  "require": {
    "php": "^8.3",
    "illuminate/contracts": "^12.0|^13.0",
    "illuminate/support": "^12.0|^13.0",
    "spatie/laravel-package-tools": "^1.92",
    "padosoft/laravel-rebel-core": "^0.1"
  },
  "require-dev": {
    "larastan/larastan": "^3.0",
    "laravel/pint": "^1.18",
    "orchestra/testbench": "^10.0|^11.0",
    "pestphp/pest": "^4.0",
    "pestphp/pest-plugin-laravel": "^4.0"
  },
  "autoload": {
    "psr-4": {
      "Padosoft\\Rebel\\Recovery\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Padosoft\\Rebel\\Recovery\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Padosoft\\Rebel\\Recovery\\RebelRecoveryServiceProvider"
      ]
    }
  },
  "scripts": {
    "test": "pest",
    "phpstan": "phpstan analyse --memory-limit=512M",
    "pint": "pint",
    "check": [
      "pint --test",
      "@phpstan",
      "@test"
    ]
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "phpstan/extension-installer": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
